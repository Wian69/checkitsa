{
  "manifest_version": 3,
  "name": "CheckItSA - Website Safety Scanner",
  "version": "1.0.0",
  "description": "Instantly check if a website is safe, verified, or a known scam directly from your browser.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Scan Website Safety"
  },
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://checkitsa.co.za/*",
    "*://*/*"
  ]
}
